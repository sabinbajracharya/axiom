error NetError {
    Timeout,
    Refused,
}

fn fetch(let url: String) -> NetError!String {
    val response = http_get(url)?
    val text = response.read_all() catch |e| match e {
        NetError.Timeout  => "timeout",
        NetError.Refused  => "refused",
    }
    val fallback = response.read_all() catch "default"
    return text
}