enum Shape {
    Circle(Int),
    Rect(Int, Int),
    Empty,
}

fn main() {
    val s = Shape::Circle(5)
    match s {
        Shape::Circle(r) => println(string::format("{}", r)),
        Shape::Rect(w, h) => println(string::format("{}", w)),
        Shape::Empty => println(string::format("{}", 0)),
    }
}
