enum Shape {
    Circle(Float),
    Rect(Float, Float),
    Empty,
}

fn describe(let s: Shape) -> Float {
    match s {
        Circle(r) => r * r,
        Rect(w, h) => w * h,
        _ => 0.0,
    }
}

fn main() {
    val c = Circle(3.0)
    val a = describe(c)
    print(string::format("{}", a))
}
