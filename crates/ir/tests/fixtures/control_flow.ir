fn main() -> fn() -> Unit {
  entry:
  %0 = Const Int(1)
  %1 = Const Int(0)
  %2 = BinOp > %0 %1
  Branch %2 then_0 else_2
  then_0:
  %4 = Const String("positive")
  %6 = Const String("positive")
  %7 = Call print [%6]
  %3 = Copy %7
  Jump if_merge_1
  else_2:
  %8 = Const String("non-positive")
  %10 = Const String("non-positive")
  %11 = Call print [%10]
  %3 = Copy %11
  Jump if_merge_1
  if_merge_1:
  Return %3
}

