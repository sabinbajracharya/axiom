fn main() -> fn() -> Unit {
  entry:
  %0 = Const Int(3)
  %1 = Const Int(4)
  %3 = Const Int(3)
  %4 = Const Int(4)
  %5 = Call sum_of_squares [%3, %4]
  %6 = Const Unit
  Return %6
}

fn square(x: Int) -> fn(Int) -> Int {
  entry:
  %1 = BinOp * %0 %0
  Return %1
}

fn sum_of_squares(a: Int, b: Int) -> fn(Int, Int) -> Int {
  entry:
  %3 = Call square [%0]
  %5 = Call square [%1]
  %6 = BinOp + %3 %5
  Return %6
}

