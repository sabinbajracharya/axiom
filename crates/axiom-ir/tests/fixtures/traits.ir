fn Circle::area(self: Circle) -> fn(Circle) -> Float {
  entry:
  %1 = Const Float(3.14159)
  %2 = Field %0 r
  %3 = BinOp * %1 %2
  %4 = Field %0 r
  %5 = BinOp * %3 %4
  Return %5
}

fn Circle::name(self: <Self>) -> String {
  entry:
  %1 = Const String("shape")
  Return %1
}

fn main() -> fn() -> Unit {
  entry:
  %0 = Const Float(3)
  %1 = StructNew Circle {r: %0}
  %2 = MethodCall %1 Circle::area []
  %3 = Call print [%2]
  Return %3
}

