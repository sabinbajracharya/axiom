fn Point::origin() -> fn() -> Point {
  entry:
  %0 = Const Float(0)
  %1 = Const Float(0)
  %2 = StructNew Point {x: %0, y: %1}
  Return %2
}

fn Point::translate(self: Point, dx: Float, dy: Float) -> fn(Point, Float, Float) -> Unit {
  entry:
  %3 = Field %0 x
  %4 = BinOp + %3 %1
  %4294967295 = Copy %4
  %5 = Const Unit
  Return %5
}

