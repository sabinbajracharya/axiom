fn square(x: Int) -> fn(Int) -> Int {
  entry:
  %1 = BinOp * %0 %0
  Return Unit
}

fn sum_of_squares(a: Int, b: Int) -> fn(Int, Int) -> Int {
  entry:
  %2 = Call square [%0]
  %3 = Call square [%1]
  %4 = BinOp + %2 %3
  Return Unit
}

fn main() -> fn() -> Unit {
  entry:
  %0 = Const Int(3)
  %1 = Const Int(4)
  %2 = Call sum_of_squares [%0, %1]
  %3 = Const Unit
  Return Unit
}

