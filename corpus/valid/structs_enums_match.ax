// Structs, enums, and exhaustive match — the headline v0 type-system feature.
struct Point {
    x: Float,
    y: Float,
}
enum Shape {
    Circle(Float),
    Rect(Float, Float),
    Empty,
}
fn main() {
    val origin = Point { x: 0.0, y: 0.0 }
    val x = origin.x
    val s = Empty
    val result = match s {
        Circle(r) => 3.14 * r * r
        Rect(w, h) => w * h
        Empty => 0.0
    }
}