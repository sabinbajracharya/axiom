// std/io.ax -- safe I/O API
//
// Wraps core::platform write primitives with ergonomic functions.
// In multi-file mode these are real Axiom functions; in single-file
// mode the VM dispatches print/println as builtins (fallback).

use core::platform::write;

/// Write `s` to stdout (fd 1).
pub fn print(s: String) {
    write(1, s.as_bytes())
}

/// Write `s` followed by a newline to stdout (fd 1).
pub fn println(s: String) {
    write(1, s.as_bytes());
    write(1, "\n".as_bytes())
}
